# =============================================================================
# Dev runner — código embutido na imagem (Portainer / servidor)
# Hot-reload local: use docker-compose.dev.local.yml junto com este compose
# Usage: docker compose -f docker-compose.dev.yml up --build
# =============================================================================

FROM node:22-bookworm-slim

RUN npm install -g pnpm@10.18.3

RUN apt-get update \
  && apt-get install -y --no-install-recommends python3 make g++ \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

ENV PUPPETEER_SKIP_DOWNLOAD=true
ENV NODE_OPTIONS="--max-old-space-size=4096"

COPY .npmrc package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY apps/api/package.json ./apps/api/
COPY apps/web/package.json ./apps/web/
COPY apps/pwa/package.json ./apps/pwa/
COPY apps/pwa-lideranca/package.json ./apps/pwa-lideranca/
COPY packages/contracts/package.json ./packages/contracts/
COPY packages/eslint-config/package.json ./packages/eslint-config/
COPY packages/typescript-config/package.json ./packages/typescript-config/
COPY packages/ui/package.json ./packages/ui/

RUN pnpm --version \
  && pnpm fetch \
  && pnpm install --offline --frozen-lockfile --ignore-scripts

# Código-fonte na imagem — necessário quando não há bind-mount (Portainer)
COPY apps ./apps
COPY packages ./packages
COPY scripts ./scripts

RUN pnpm --filter @lilog/contracts build

COPY scripts/docker-dev-entrypoint.sh /usr/local/bin/docker-dev-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-dev-entrypoint.sh

EXPOSE 3000 3001 5174 5175

ENTRYPOINT ["docker-dev-entrypoint.sh"]
CMD ["pnpm", "dev"]
