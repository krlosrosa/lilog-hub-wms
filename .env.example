# =============================================================================
# Lilog Hub — Docker / Portainer (copie para .env na raiz do projeto)
# =============================================================================

# --- Traefik hosts (produção) ---
API_HOST=api.seudominio.com.br
WEB_HOST=admin.seudominio.com.br
PWA_HOST=pwa.seudominio.com.br
PWA_LIDERANCA_HOST=lideranca.seudominio.com.br

# --- API (NestJS) ---
NODE_ENV=production
PORT=3001
DATABASE_URL=postgres://user:pass@host:5432/lilog
DB_POOL_MAX=10
JWT_SECRET=troque-por-um-segredo-forte

# Origens permitidas no CORS (URLs dos frontends em produção)
CORS_ORIGIN=https://admin.seudominio.com.br,https://pwa.seudominio.com.br,https://lideranca.seudominio.com.br

# --- Redis (serviço interno do compose) ---
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_USERNAME=

# --- Ravex ---
RAVEX_BASE_URL=https://api.rest.app.ravex.com.br
RAVEX_USERNAME=seu-email@ravex.com.br
RAVEX_PASSWORD=sua-senha

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=
R2_API_TOKEN=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# --- Build-time: Web (Next.js) ---
NEXT_PUBLIC_API_URL=https://api.seudominio.com.br/api

# --- Build-time: PWAs (Vite) — URL pública da API ---
VITE_API_URL=https://api.seudominio.com.br/api
VITE_API_PORT=443
