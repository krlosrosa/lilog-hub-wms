# =============================================================================
# Lilog Hub — Docker / Portainer (copie para .env na raiz do projeto)
#
# docker-compose.dev.yml        → dev local / stack única (todos os apps juntos)
# docker-compose.portainer.yml  → produção no Portainer (1 container por app)
# docker-compose.yml            → alias de produção (mesma estrutura)
# =============================================================================

# --- Traefik hosts ---
API_HOST=api-dev.logistica-processo.com
WEB_HOST=admin-dev.logistica-processo.com
PWA_HOST=pwa-dev.logistica-processo.com
PWA_LIDERANCA_HOST=lideranca-dev.logistica-processo.com
PORTAL_HOST=portal-dev.logistica-processo.com

# --- URLs públicas (API, Swagger e filas Bull Board) ---
# Swagger: disponível apenas com NODE_ENV=development (docker-compose.dev.yml)
# Bull Board (/queues): requer JWT admin em produção
API_PUBLIC_URL=https://api-dev.logistica-processo.com
SWAGGER_PUBLIC_URL=https://api-dev.logistica-processo.com/api/docs
BULL_BOARD_PUBLIC_URL=https://api-dev.logistica-processo.com/queues
PWA_BASE_URL=https://pwa-dev.logistica-processo.com

# --- API (NestJS) ---
NODE_ENV=production
PORT=3001
DATABASE_URL=postgres://user:pass@host:5432/lilog
DB_POOL_MAX=10
JWT_SECRET=troque-por-um-segredo-forte

# Origens permitidas no CORS (URLs dos frontends em produção)
CORS_ORIGIN=https://admin-dev.logistica-processo.com,https://pwa-dev.logistica-processo.com,https://lideranca-dev.logistica-processo.com,https://portal-dev.logistica-processo.com

# Cookie compartilhado entre subdomínios (admin-dev + api-dev + portal-dev)
COOKIE_DOMAIN=.logistica-processo.com
COOKIE_SECURE=true

# --- Redis (serviço interno do compose) ---
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_USERNAME=

# --- Ravex ---
RAVEX_BASE_URL=https://api.rest.app.ravex.com.br
RAVEX_USERNAME=seu-email@ravex.com.br
RAVEX_PASSWORD=sua-senha

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=
R2_API_TOKEN=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# --- Build-time / runtime: Web e Portal (Next.js) ---
NEXT_PUBLIC_API_URL=https://api-dev.logistica-processo.com/api

# --- Build-time: PWAs (Vite) — URL pública da API ---
VITE_API_URL=https://api-dev.logistica-processo.com/api
VITE_API_PORT=443
