# Base da API. Em dev no PC: /api (proxy Vite). No celular (LAN) o app troca automaticamente para http://<IP>:3001/api.
VITE_API_URL=/api
VITE_API_PORT=3001
# Opcional: forçar proxy do Vite no celular (http://<IP>:5174/api) em vez de porta 3001 direta.
# VITE_API_USE_PROXY=true

# Sentry — projeto lilog-pwa (Settings > Projects > lilog-pwa > Client Keys)
VITE_SENTRY_DSN=

# Replicache pilot (/recebimento-rc) — v15+ não exige license key no client.
# Auth usa cookie de sessão (credentials: include) nos endpoints /api/replicache/recebimento/*.

# Auth token para upload de source maps no build (Settings > Auth Tokens)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=lilog-pwa
