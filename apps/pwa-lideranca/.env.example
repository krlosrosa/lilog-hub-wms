# Base da API. Em dev no PC: /api (proxy Vite). No celular (LAN) o app troca automaticamente para http://<IP>:3001/api.
VITE_API_URL=/api
VITE_API_PORT=3001
# No celular/LAN, use o proxy do Vite para evitar CORS (recomendado):
# VITE_API_USE_PROXY=true

# Sentry — projeto lilog-pwa-lideranca (Settings > Projects > lilog-pwa-lideranca > Client Keys)
VITE_SENTRY_DSN=

# Auth token para upload de source maps no build (Settings > Auth Tokens)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=lilog-pwa-lideranca
