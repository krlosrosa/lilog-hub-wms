DATABASE_URL=postgres://user:pass@localhost:5432/lilog

JWT_SECRET=supersecret

PORT=3001

CORS_ORIGIN=http://localhost:3000,http://localhost:5174,http://localhost:5175,http://192.168.1.3:5174,http://192.168.1.3:5175

NODE_ENV=development

REDIS_HOST=localhost

REDIS_PORT=6379

# REDIS_PASSWORD=your-redis-password

RAVEX_BASE_URL=https://api.rest.app.ravex.com.br
RAVEX_USERNAME=seu-email@ravex.com.br
RAVEX_PASSWORD=sua-senha

# Cloudflare R2 via API S3 compatível (@aws-sdk/client-s3)
# Dashboard: R2 > Manage R2 API Tokens > Create API token
# Permissão: Object Read & Write no bucket (não use token só de leitura)
#
# Forma recomendada (o que o dashboard R2 mostra):
R2_ACCOUNT_ID=
R2_API_TOKEN=          # token cfat_... exibido na criação
R2_BUCKET_NAME=
#
# Alternativa avançada (credenciais S3 explícitas, se você as tiver):
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# Opcional: ID do token (senão a API resolve via /user/tokens/verify)
# R2_TOKEN_ID=
# Opcional: região R2 (padrão auto). Valores: auto | wnam | enam | weur | apac
# R2_REGION=auto
# Opcional: endpoint S3 explícito (substitui https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com)
# R2_S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=
# Opcional: URL pública da API para upload local em desenvolvimento (sem R2)
# API_PUBLIC_URL=http://localhost:3001
