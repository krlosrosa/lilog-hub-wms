{
  "extends": "@lilog/typescript-config/base.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM"],
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/**/*.spec.ts"]
}
